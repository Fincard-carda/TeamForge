# ============================================================
# TeamForge environment variables
# ============================================================
# This file is .env.example — copy it to .env and fill in real values:
#   cp .env.example .env
# .env must never be committed to git (it is already in .gitignore).

# --- Standard Claude API key (for model calls and setup wizard) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional model overrides
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_LEAD=claude-opus-4-6

# --- Admin API key (service account for usage/cost monitoring) ---
# IMPORTANT: create a dedicated admin key, separate from your personal one.
# Console > Settings > Admin Keys > "Create key"
#   Name: teamforge-usage-monitor
#   (this name helps you attribute calls back to TeamForge)
#
# Auth note: Anthropic's current auth model only lets admin keys hit the
# cost/usage endpoints. There is no service-account alternative for these
# specific endpoints. TeamForge wraps the admin key with three defensive
# layers in tools/analytics.py:
#   1. Allowlist — only 4 read-only endpoints can be reached
#   2. Audit log — every call goes to state/admin_api_audit.json
#   3. Rate limit — 60 calls/hour cap
# Details: docs/SERVICE_ACCOUNT.md
#
# Rotation suggestion: delete + recreate every 3 months from Console.
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin01-...

# --- Dashboard ---
TEAMFORGE_DASHBOARD=on
TEAMFORGE_DASHBOARD_PORT=7777

# --- Live log ---
TEAMFORGE_LIVE=on
LOG_LEVEL=INFO

# --- Concurrency limit ---
# How many agent subprocesses can run at once? On Windows this prevents
# paging-file blowups (WinError 1455) and "too many processes" crashes.
# Default 4. Verify RAM/CPU before increasing.
TEAMFORGE_MAX_CONCURRENT=4

# --- Prompt caching ---
# The Claude Agent SDK enables 5-minute ephemeral cache by default. Because
# TeamForge spawns many sub-agents, a 1-hour cache delivers far bigger savings.
# Cost trade-off: cache_creation tokens cost ~25% more than uncached input,
# but cache_read costs ~90% less. Net effect for a system that chain-delegates
# or fans out asynchronously: 50-70% input-token savings.
#
# To disable entirely: DISABLE_PROMPT_CACHING=1
# (per-model variants exist too: DISABLE_PROMPT_CACHING_OPUS / SONNET / HAIKU)
ENABLE_PROMPT_CACHING_1H=1

# When the orchestrator starts, automatically open the dashboard in the
# default browser. Set to off/false/0 to disable (URL is still logged).
TEAMFORGE_AUTO_OPEN=on

# --- Workspace filter (analytics) ---
# Restrict Anthropic Admin API cost/usage queries to a single workspace.
# Leaving this blank includes every workspace in the org (Default workspace,
# workbench, etc.). Find the workspace ID under
# Console > Settings > Workspaces.
TEAMFORGE_WORKSPACE_ID=

# --- Automatic budget monitor ---
# Background coroutine pulls real Anthropic spend every N minutes and checks
# it against monthly_cap:
#   soft  (>= 75%)  -> automatic CEO warning + optimization suggestions
#   hard  (>= 95%)  -> automatic CEO halt + user approval requested
# Disable with TEAMFORGE_BUDGET_MONITOR=off.
TEAMFORGE_BUDGET_MONITOR=on
TEAMFORGE_BUDGET_CHECK_INTERVAL_MIN=60
